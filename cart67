<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI', sans-serif;
    }

    body {
        background: linear-gradient(135deg, #1e1e2f, #3a0ca3);
        color: white;
        padding: 40px;
    }

    h1 {
        text-align: center;
        margin-bottom: 40px;
        font-size: 2.5rem;
        letter-spacing: 2px;
    }

    .container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
    }

    .card {
        background: rgba(255, 255, 255, 0.08);
        border-radius: 15px;
        padding: 20px;
        backdrop-filter: blur(10px);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 25px rgba(0,0,0,0.3);
    }

    .card h2 {
        font-size: 1.4rem;
        margin-bottom: 10px;
    }

    .language {
        display: inline-block;
        padding: 5px 10px;
        font-size: 0.8rem;
        border-radius: 20px;
        background: #7209b7;
        margin-bottom: 10px;
    }

    .rank {
        position: absolute;
        top: 10px;
        right: 15px;
        font-size: 1.2rem;
        font-weight: bold;
        color: #f72585;
    }

    .card p {
        font-size: 0.9rem;
        opacity: 0.85;
    }

    footer {
        text-align: center;
        margin-top: 40px;
        font-size: 0.9rem;
        opacity: 0.7;
    }
</style>

</head>
